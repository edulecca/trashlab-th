# Copy to .env and fill with your own PostgreSQL connection string.
# Local, or a hosted free tier such as Neon / Supabase.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# Anthropic API key for AI bill extraction (the Vercel AI SDK reads it automatically).
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-..."
